# --- Database (Postgres) ---
# Use a hosted Postgres (Neon free tier recommended). On serverless (Vercel),
# use the POOLED connection string. The same URL works for local dev.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Strava API (https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID="your_client_id"
STRAVA_CLIENT_SECRET="your_client_secret"
# Random string you choose; used to verify Strava webhook subscription:
STRAVA_WEBHOOK_VERIFY_TOKEN="pick-any-random-string"

# --- App ---
# Public base URL of the deployed app (no trailing slash). Used for OAuth redirect + webhook callback.
APP_BASE_URL="http://localhost:3000"
# Simple shared password to access manual controls (set/override rotation, add laps).
ADMIN_PASSWORD="change-me"

# --- Event configuration (defaults; also editable in-app) ---
EVENT_NAME="Endure24"
TEAM_NAME="Team Name"
# ISO 8601 start time of the 24h event, with timezone offset:
EVENT_START="2026-07-18T12:00:00+01:00"
EVENT_DURATION_HOURS="24"
LAP_DISTANCE_MILES="5"
